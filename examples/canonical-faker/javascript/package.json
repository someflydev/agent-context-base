{
  "name": "canonical-faker-js",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "node --loader ts-node/esm src/index.ts",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand --testPathPatterns=smoke.test.ts"
  },
  "dependencies": {
    "@faker-js/faker": "^8.4.1",
    "chance": "^1.1.11"
  },
  "devDependencies": {
    "@types/chance": "^1.1.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/__tests__"
    ],
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  }
}
