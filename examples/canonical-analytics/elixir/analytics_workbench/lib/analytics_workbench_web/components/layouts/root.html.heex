<!DOCTYPE html>
<html lang="en" class="[word-break:break-word]">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <title>{assigns[:page_title] || "Analytics Workbench"}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/htmx.org@1.9.10"></script>
    <script src="https://cdn.plot.ly/plotly-2.27.0.min.js"></script>
  </head>
  <body class="bg-gray-50 text-gray-900 font-sans antialiased">
    <header class="bg-white border-b border-gray-200">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
          <div class="flex items-center gap-4">
            <span class="text-xl font-bold text-blue-600">Analytics Workbench</span>
            <div class="hidden sm:ml-6 sm:flex sm:space-x-4">
              <a href={~p"/"} class={["px-3 py-2 rounded-md text-sm font-medium", @conn.request_path == "/" && "bg-blue-100 text-blue-700"]}>Overview</a>
              <a href={~p"/trends"} class={["px-3 py-2 rounded-md text-sm font-medium", @conn.request_path == "/trends" && "bg-blue-100 text-blue-700"]}>Trends</a>
              <a href={~p"/services"} class={["px-3 py-2 rounded-md text-sm font-medium", @conn.request_path == "/services" && "bg-blue-100 text-blue-700"]}>Services</a>
              <a href={~p"/distributions"} class={["px-3 py-2 rounded-md text-sm font-medium", @conn.request_path == "/distributions" && "bg-blue-100 text-blue-700"]}>Distributions</a>
              <a href={~p"/heatmap"} class={["px-3 py-2 rounded-md text-sm font-medium", @conn.request_path == "/heatmap" && "bg-blue-100 text-blue-700"]}>Heatmap</a>
              <a href={~p"/funnel"} class={["px-3 py-2 rounded-md text-sm font-medium", @conn.request_path == "/funnel" && "bg-blue-100 text-blue-700"]}>Funnel</a>
              <a href={~p"/incidents"} class={["px-3 py-2 rounded-md text-sm font-medium", @conn.request_path == "/incidents" && "bg-blue-100 text-blue-700"]}>Incidents</a>
            </div>
          </div>
        </div>
      </nav>
    </header>

    <main class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
      {@inner_content}
    </main>

    <footer class="bg-white border-t border-gray-200 py-4 mt-8">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-sm text-gray-500">
        Fixture Profile: smoke | Seed: 42 | Elixir / Phoenix / HTMX / Plotly
      </div>
    </footer>
  </body>
</html>
